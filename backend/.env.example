# Database Configuration
# Provide your PostgreSQL connection URL
DATABASE_URL="postgresql://username:password@localhost:5432/skillswap?schema=public"

# Server Configuration
PORT=5000
JWT_SECRET="your_super_secret_jwt_key_here"

# S3 / Cloudflare R2 Storage Configuration
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="skillswap-bucket"
# Optional: Only needed if using Cloudflare R2 or custom S3 compatible service
# S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"

# Razorpay Configuration (India Payments)
RAZORPAY_KEY_ID="rzp_test_xxxxxxx"
RAZORPAY_KEY_SECRET="rzp_secret_xxxxxxx"
